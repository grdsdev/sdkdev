{
  "name": "@supabase/sdkdev",
  "version": "0.1.0",
  "description": "SDK development tools for Supabase",
  "type": "module",
  "bin": {
    "sdkdev": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "generate": "tsx ./src/cli.ts",
    "test": "npm run test:e2e",
    "test:e2e": "./tests/e2e/compile-tests.sh",
    "test:quick": "./tests/e2e/quick-test.sh"
  },
  "keywords": [
    "supabase",
    "sdk",
    "codegen",
    "typescript"
  ],
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "commander": "^12.0.0"
  }
}
